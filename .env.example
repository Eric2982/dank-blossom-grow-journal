# Copy this file to .env.local and fill in your values.
# .env.local is committed to the repository as the primary config file for this project.

# Base44 app configuration (required)
VITE_BASE44_APP_ID=your_app_id
VITE_BASE44_APP_BASE_URL=your_backend_url

# Google API key — used for Google services (e.g. Maps, Gemini AI)
# Obtain from https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_API_KEY=your_google_api_key

# Cloud Run custom audience — the audience string registered on the Cloud Run
# service via:
#   gcloud run services update SERVICE --add-custom-audiences=AUDIENCE
# Incoming OIDC ID tokens must carry this value in their `aud` claim.
# Leave unset to disable audience verification (e.g. in local development).
CLOUD_RUN_CUSTOM_AUDIENCE=
