{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dbgj-assetlinks-worker",
  "compatibility_date": "2026-03-12",
  "send_metrics": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
