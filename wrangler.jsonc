{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dbgj-assetlinks-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-03-12",
  "send_metrics": false,
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "BASE44_APP_BASE_URL": "https://my-to-do-list-81bfaad7.base44.app"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
